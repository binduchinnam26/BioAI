# BioLitAI-X Environment Configuration
# Fill in your credentials before running the application

# PubMed/NCBI Entrez credentials
ENTREZ_EMAIL=your_email@example.com
ENTREZ_API_KEY=your_ncbi_api_key_here

# Google Gemini API key (required for Phase 5 hypothesis generation)
GEMINI_API_KEY=your_gemini_api_key_here
